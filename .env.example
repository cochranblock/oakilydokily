# OakilyDokily — Environment Variables
# Copy to .env and fill in values.

# Server
PORT=3000
BIND=0.0.0.0
OD_BASE_URL=https://oakilydokily.com

# Session (required for auth — generate with: openssl rand -hex 32)
SESSION_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth (optional)
FB_APP_ID=
FB_APP_SECRET=

# Apple Sign In (optional)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Gmail API (optional — service account for waiver emails)
GOOGLE_APPLICATION_CREDENTIALS=
GMAIL_IMPERSONATE_USER=
GMAIL_FROM=

# Resend (optional — fallback email provider)
RESEND_API_KEY=
RESEND_FROM=OakilyDokily <noreply@oakilydokily.com>

# Cloudflare Turnstile (optional — captcha on waiver form)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# D1 sharded auth (optional)
# OD_AUTH_D1=1
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# OD_D1_SHARD_IDS=

# Analytics (optional)
GA4_MEASUREMENT_ID=

# Booking link (optional — Calendly or similar)
OD_BOOK_CALL_URL=

# Data directory (default: platform data dir)
# OAKILYDOKILY_DATA_DIR=
# COCHRANBLOCK_DATA_ROOT=

# Approuter registration (optional — only with --features approuter)
# OD_HOSTNAMES=oakilydokily.com,www.oakilydokily.com
# OD_BACKEND_URL=http://127.0.0.1:3000

# Manual users (optional — comma-separated email_hash:bcrypt_hash pairs)
# OD_MANUAL_USERS=

# Override URLs (optional — for testing/staging)
# OD_OAUTH2_TOKEN_URL=https://oauth2.googleapis.com/token
# OD_OPENID_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
# OD_GMAIL_API_BASE=https://gmail.googleapis.com

# Test mode (optional — for integration testing)
# OD_TEST_MOCK_OAUTH=0
# OD_TEST_WAIVER_BYPASS=0
